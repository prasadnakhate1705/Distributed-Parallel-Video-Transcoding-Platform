# AWS credentials
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1

# S3
S3_BUCKET=video-transcoder-input1

# DynamoDB
JOBS_TABLE=TranscodeJobs

# API authentication — generate with: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=your_api_key_here

# API → Frontend
FLASK_URL=http://localhost:5000

# Spark cluster (set from: terraform output spark_master_url)
# local[*] = run on this machine using all CPU cores (default for local dev)
# spark://x.x.x.x:7077 = standalone cluster on EC2
SPARK_MASTER_URL=local[*]

# Worker tuning (optional)
POLL_INTERVAL=30
SEGMENT_DURATION=120
MAX_RETRIES=3
WORKER_COUNT=2
EXECUTOR_MEMORY=2g
EXECUTOR_CORES=2
